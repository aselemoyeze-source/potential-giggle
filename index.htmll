<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Mimi Gold Collection</title>

<style>

body{
margin:0;
font-family:Arial;
background:#0b0b0b;
color:white;
}

header{
background:black;
padding:15px;
text-align:center;
border-bottom:2px solid gold;
}

.logo{
font-size:30px;
color:gold;
font-weight:bold;
}

.hero{
padding:80px 20px;
text-align:center;
background:#111;
}

.hero h1{
color:gold;
}

.search{
text-align:center;
padding:20px;
}

input,textarea{
padding:10px;
width:90%;
max-width:400px;
margin:5px;
}

button{
background:gold;
border:none;
padding:10px 20px;
cursor:pointer;
margin:5px;
font-weight:bold;
}

.filters{
text-align:center;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:20px;
}

.card{
background:#1a1a1a;
padding:15px;
border-radius:10px;
text-align:center;
}

.card img{
width:100%;
height:250px;
object-fit:cover;
border-radius:10px;
}

.cart{
background:#111;
padding:20px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
gap:10px;
padding:20px;
}

.gallery div{
border:1px solid gold;
padding:40px;
text-align:center;
}

section{
padding:20px;
}

footer{
background:black;
padding:20px;
text-align:center;
border-top:2px solid gold;
}

</style>

</head>

<body>

<header>

<div class="logo">
👑 MIMI GOLD COLLECTION
</div>

</header>

<div class="hero">

<h1>Luxury Fashion For Every Generation</h1>

<p>Elegance Woven In Gold</p>

</div>

<div class="search">

<input
type="text"
id="search"
placeholder="Search Products">

</div>

<div class="filters">

<button onclick="filterProducts('all')">
All
</button>

<button onclick="filterProducts('Men')">
Men
</button>

<button onclick="filterProducts('Women')">
Women
</button>

<button onclick="filterProducts('Kids')">
Kids
</button>

</div>

<div class="products" id="products"></div>

<section class="cart">

<h2>
🛒 Cart
(<span id="cartCount">0</span>)
</h2>

<div id="cartItems"></div>

<h3>
Total:
₦<span id="total">0</span>
</h3>

<button onclick="checkoutWhatsApp()">

Checkout On WhatsApp

</button>

</section>

<section>

<h2>Customer Reviews</h2>

<p id="review">

⭐⭐⭐⭐⭐ Amazing quality and delivery.

</p>

</section>

<section>

<h2>Instagram Gallery</h2>

<div class="gallery">

<div>Photo</div>
<div>Photo</div>
<div>Photo</div>
<div>Photo</div>

</div>

<p>
Instagram:
@Oyeze_67
</p>

</section>

<section>

<h2>Track Delivery</h2>

<input
id="tracking"
placeholder="Tracking Number">

<button onclick="trackOrder()">
Track
</button>

<p id="trackingResult"></p>

</section>

<section>

<h2>Contact Us</h2>

<input
id="name"
placeholder="Your Name">

<br>

<input
id="email"
placeholder="Your Email">

<br>

<textarea
id="message"
placeholder="Message"></textarea>

<br>

<button onclick="sendMessage()">

Send Message

</button>

</section>

<footer>

<p>
📞 09018653469
</p>

<p>
📧 aselemoyeze@gmail.com
</p>

<p>
Instagram: @Oyeze_67
</p>

</footer>

<script>

const products=[

{
id:1,
name:"Luxury Senator Wear",
price:45000,
category:"Men",
image:"https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=800"
},

{
id:2,
name:"Elegant Gown",
price:38000,
category:"Women",
image:"https://images.unsplash.com/photo-1496747611176-843222e1e57c?w=800"
},

{
id:3,
name:"Kids Native Wear",
price:22000,
category:"Kids",
image:"https://images.unsplash.com/photo-1503919545889-aef636e10ad4?w=800"
}

];

let cart=[];

function displayProducts(list){

const container=
document.getElementById("products");

container.innerHTML="";

list.forEach(product=>{

container.innerHTML+=`

<div class="card">

<img src="${product.image}">

<h3>${product.name}</h3>

<p>
₦${product.price.toLocaleString()}
</p>

<button
onclick="addToCart(${product.id})">

Add To Cart

</button>

</div>

`;

});

}

displayProducts(products);

function addToCart(id){

const product=
products.find(
p=>p.id===id
);

const existing=
cart.find(
item=>item.id===id
);

if(existing){

existing.qty++;

}else{

cart.push({

...product,
qty:1

});

}

updateCart();

}

function updateCart(){

let total=0;

let count=0;

let html="";

cart.forEach((item,index)=>{

total +=
item.price * item.qty;

count += item.qty;

html += `

<div>

${item.name}

<br>

<button
onclick="decreaseQty(${index})">

-

</button>

${item.qty}

<button
onclick="increaseQty(${index})">

+

</button>

<button
onclick="removeItem(${index})">

Remove

</button>

</div>

<hr>

`;

});

document
.getElementById("cartItems")
.innerHTML=html;

document
.getElementById("cartCount")
.innerText=count;

document
.getElementById("total")
.innerText=
total.toLocaleString();

}

function increaseQty(index){

cart[index].qty++;

updateCart();

}

function decreaseQty(index){

if(cart[index].qty>1){

cart[index].qty--;

}else{

cart.splice(index,1);

}

updateCart();

}

function removeItem(index){

cart.splice(index,1);

updateCart();

}

function checkoutWhatsApp(){

let message=

"🛍 MIMI GOLD COLLECTION ORDER%0A%0A";

cart.forEach(item=>{

message +=

item.name +

" x " +

item.qty +

"%0A";

});

window.open(

"https://wa.me/2349018653469?text="

+

message

);

}

function sendMessage(){

let name=
document.getElementById("name").value;

let email=
document.getElementById("email").value;

let message=
document.getElementById("message").value;

let text=

"Name: "+name+

"%0AEmail: "+email+

"%0AMessage: "+message;

window.open(

"https://wa.me/2349018653469?text="

+

text

);

}

document
.getElementById("search")
.addEventListener("keyup",function(){

let value=
this.value.toLowerCase();

displayProducts(

products.filter(product=>

product.name
.toLowerCase()
.includes(value)

)

);

});

function filterProducts(category){

if(category==="all"){

displayProducts(products);

}else{

displayProducts(

products.filter(product=>

product.category===category

)

);

}

}

let reviews=[

"⭐⭐⭐⭐⭐ Amazing quality and delivery.",

"⭐⭐⭐⭐⭐ Luxury fashion and excellent service.",

"⭐⭐⭐⭐⭐ Beautiful outfits and affordable."

];

let current=0;

setInterval(()=>{

current++;

if(current>=reviews.length){

current=0;

}

document
.getElementById("review")
.innerText=
reviews[current];

},3000);

function trackOrder(){

let number=

document.getElementById(
"tracking"
).value;

document.getElementById(
"trackingResult"
).innerHTML=

"Tracking ID: "

+

number

+

"<br>Package is currently in transit.";

}

</script>

</body>
</html>
